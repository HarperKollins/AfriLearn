# AfriLearn Environment Configuration
# Copy this file to .env and fill in your values

# ── Application ──────────────────────────────────────
APP_ENV=development
PORT=8080

# ── PostgreSQL Database ───────────────────────────────
# Option 1: Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=afrilearn
DB_SSLMODE=disable

# Option 2: Neon.tech (free cloud PostgreSQL)
# Replace the DB_* vars above with your Neon connection string
# DB_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/afrilearn?sslmode=require

# ── API Keys (for future use) ─────────────────────────
# GEMINI_API_KEY=your_gemini_key_here
